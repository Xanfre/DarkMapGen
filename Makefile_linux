objdir = ./objs

PREFIX ?= /usr
BINDIR = $(PREFIX)/bin
DOCDIR = $(PREFIX)/share/doc/DarkMapGen
LICDIR = $(PREFIX)/share/licenses/DarkMapGen

CXX ?= g++

CXXFLAGS_ALL = -O2 $(CXXFLAGS)
CPPFLAGS_ALL = -std=gnu++11 -Wall -Wextra -Wno-unused -Wno-unused-result $(CPPFLAGS)

ifeq ($(STATIC),)
	LDFLAGS_FLTK = $(shell fltk-config --use-images --ldflags) $(shell pkg-config --libs libpng)
else
	LDFLAGS_FLTK = $(shell fltk-config --use-images --ldstaticflags) $(shell pkg-config --libs --static libpng) -static
endif

LDFLAGS_ALL = $(LDFLAGS_FLTK) $(LDFLAGS)

OBJS = $(objdir)/mapgen.o \
	$(objdir)/Fle_Colors.o \
	$(objdir)/Fle_Schemes.o

.PHONY: all install clean

all: $(objdir) DarkMapGen

install:
	mkdir -p $(DESTDIR)$(BINDIR)
	mkdir -p $(DESTDIR)$(DOCDIR)
	mkdir -p $(DESTDIR)$(LICDIR)
	install -p -m 755 DarkMapGen $(DESTDIR)$(BINDIR)
	install -p -m 644 DarkMapGen-ReadMe.txt $(DESTDIR)$(DOCDIR)
	install -p -m 644 license.txt $(DESTDIR)$(LICDIR)/LICENSE

clean:
	rm -rf $(objdir)
	rm -f DarkMapGen

$(objdir):
	mkdir -p $@

$(objdir)/%.o: %.cxx
	$(CXX) $(CXXFLAGS_ALL) $(CPPFLAGS_ALL) -c -o $@ $<

$(objdir)/%.o: %.cpp
	$(CXX) $(CXXFLAGS_ALL) $(CPPFLAGS_ALL) -c -o $@ $<

$(objdir)/mapgen.o: dmg_curs.h Fle_Colors.hpp Fle_Schemes.hpp

DarkMapGen: $(OBJS)
	$(CXX) $(CXXFLAGS_ALL) $^ -o $@ $(LDFLAGS_ALL)
